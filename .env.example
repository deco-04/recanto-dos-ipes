# ── Database (Railway PostgreSQL addon — auto-provided by Railway) ──────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Redis (Railway Redis addon — for persistent rate limiting) ─────────────────
# Auto-provided by Railway when a Redis addon is attached to the project.
# Without this, rate-limiting falls back to in-memory Maps (resets on restart).
REDIS_URL="redis://default:password@host:6379"

# ── Session ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET="replace-with-64-char-random-hex-string"

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Google OAuth ────────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_CALLBACK_URL="https://recanto-dos-ipes-production.up.railway.app/api/auth/google/callback"

# ── Gmail SMTP (for OTP codes) ─────────────────────────────────────────────────
# Enable 2FA on Gmail → Google Account → Security → App Passwords → Create App Password
GMAIL_USER="seuemail@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
EMAIL_FROM="Recanto dos Ipês <seuemail@gmail.com>"

# ── iCal Sync ──────────────────────────────────────────────────────────────────
# Airbnb: Calendar → Connect to another site → Step 1 shows your iCal export URL
AIRBNB_ICAL_URL="https://www.airbnb.com/calendar/ical/XXXXXXXXX.ics?s=YYYYY"
# Booking.com: Extranet → Calendar → Export calendar → copy iCal URL
BOOKING_COM_ICAL_URL="https://admin.booking.com/hotel/hoteladmin/ical.html?..."

# ── GoHighLevel Webhook ─────────────────────────────────────────────────────────
# Create a workflow in GHL → Add trigger "Inbound Webhook" → copy webhook URL
GHL_WEBHOOK_URL="https://services.leadconnectorhq.com/hooks/..."
GHL_BOOKING_REQUESTED_URL="https://services.leadconnectorhq.com/hooks/..."  # fired on booking.requested (new)
GHL_BOOKING_DECLINED_URL="https://services.leadconnectorhq.com/hooks/..."   # fired on booking.declined (new)

# ── Admin ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET="replace-with-random-token"

# ── Environment ────────────────────────────────────────────────────────────────
NODE_ENV="production"

# -- Push Notifications (Web Push / VAPID) -----------------------------------
# Generate keys with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY="your-vapid-public-key-here"
VAPID_PRIVATE_KEY="your-vapid-private-key-here"
VAPID_CONTACT="mailto:recantodoipes@gmail.com"

# -- AI Content Generation ---------------------------------------------------
# Get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-..."

# -- Staff App uploads (replaces Cloudinary — no external dependency) --------
# Railway: attach a Volume to this service mounted at /data
# Files stored at UPLOAD_DIR, served at /uploads/*
UPLOAD_DIR="/data/uploads"
# Public base URL for uploaded files (your Express domain)
UPLOAD_PUBLIC_URL="https://recanto-dos-ipes-production.up.railway.app"

# -- Staff App (CORS + Auth) -------------------------------------------------
STAFF_APP_ORIGIN="https://app.recantosdaserra.com"
STAFF_APP_URL="https://app.recantosdaserra.com"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STAFF_JWT_SECRET="replace-with-64-char-random-hex-string"
# Internal secret for service-to-service calls (staff app → SRI backend health/push)
STAFF_INTERNAL_SECRET="replace-with-random-token"

# -- Public URLs (used in email links, push notifications, OG tags) ----------
GUEST_SITE_URL="https://sitiorecantodosipes.com"
PUBLIC_URL="https://recanto-dos-ipes-production.up.railway.app"

# -- GoHighLevel API (CRM sync, contact creation) ----------------------------
# Get from GHL → Settings → Integrations → API Keys
GHL_API_KEY="your-ghl-api-key"
GHL_LOCATION_ID="your-ghl-location-id"

# -- Google Places (property location search) --------------------------------
GOOGLE_PLACES_API_KEY="your-places-api-key"
GOOGLE_PLACE_ID="your-google-place-id"

# -- Data Retention -----------------------------------------------------------
# Number of months to keep soft-deleted media files (default: 6)
RETENTION_MONTHS=6

# -- Porteiro / Emergency Contact --------------------------------------------
PORTEIRO_DEFAULT_PHONE="+5531XXXXXXXXX"

# -- Upload Storage Provider -------------------------------------------------
# "local" (Railway Volume) or "cloudinary" — defaults to "local"
STORAGE_PROVIDER="local"

# -- Inbox — GHL Webhook (SP4) -----------------------------------------------
GHL_WEBHOOK_SECRET=your-hmac-secret-from-ghl
GHL_WHATSAPP_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/...
GHL_INSTAGRAM_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/...

# -- Inbox — Gmail API OAuth2 (SP4, for sendInboxEmail) ----------------------
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
