# ── Google OAuth ────────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_CALLBACK_URL="https://recanto-dos-ipes-production.up.railway.app/api/auth/google/callback"

# ── Gmail SMTP (for OTP codes) ─────────────────────────────────────────────────
# Enable 2FA on Gmail → Google Account → Security → App Passwords → Create App Password
GMAIL_USER="seuemail@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
EMAIL_FROM="Recanto dos Ipês <seuemail@gmail.com>"

# ── iCal Sync ──────────────────────────────────────────────────────────────────
# Airbnb: Calendar → Connect to another site → Step 1 shows your iCal export URL
AIRBNB_ICAL_URL="https://www.airbnb.com/calendar/ical/XXXXXXXXX.ics?s=YYYYY"
# Booking.com: Extranet → Calendar → Export calendar → copy iCal URL
BOOKING_COM_ICAL_URL="https://admin.booking.com/hotel/hoteladmin/ical.html?..."

# ── GoHighLevel Webhook ─────────────────────────────────────────────────────────
# Create a workflow in GHL → Add trigger "Inbound Webhook" → copy webhook URL
GHL_WEBHOOK_URL="https://services.leadconnectorhq.com/hooks/..."

# ── Admin ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET="replace-with-random-token"

# ── Environment ────────────────────────────────────────────────────────────────
NODE_ENV="production"

