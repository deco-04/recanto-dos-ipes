datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Users ─────────────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  phone        String?
  cpf          String?  @unique
  googleId     String?  @unique
  avatarUrl    String?
  passwordHash String?  // optional — set by user after first OTP login
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pushSubscription Json?

  codes        VerificationCode[]
  bookings     Booking[]
  reputation   GuestReputation?
  guestsAdded  BookingGuest[]     @relation("GuestsAdded")
  guestProfile BookingGuest[]     @relation("GuestProfile")
}

// Sessions are managed by connect-pg-simple (its own "session" table, auto-created)
// We do not model them in Prisma — userId is stored inside the session JSON.

// ── Verification Codes (email OTP) ────────────────────────────────────────────
model VerificationCode {
  id        String      @id @default(cuid())
  email     String
  code      String
  purpose   CodePurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime    @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([email])
}

enum CodePurpose {
  LOGIN
  LINK_BOOKING
}

// ── Bookings ──────────────────────────────────────────────────────────────────
model Booking {
  id                    String        @id @default(cuid())
  userId                String?
  guestName             String
  guestEmail            String
  guestPhone            String
  guestCpf              String?
  checkIn               DateTime      @db.Date
  checkOut              DateTime      @db.Date
  nights                Int
  guestCount            Int
  extraGuests           Int           @default(0)
  hasPet                Boolean       @default(false)
  baseRatePerNight      Decimal       @db.Decimal(10, 2)
  extraGuestFee         Decimal       @db.Decimal(10, 2)
  petFee                Decimal       @db.Decimal(10, 2)
  totalAmount           Decimal       @db.Decimal(10, 2)
  status                BookingStatus @default(PENDING)
  stripePaymentIntentId String?       @unique
  invoiceNumber         String        @unique @default(cuid())
  notes                 String?
  source                BookingSource @default(DIRECT)
  externalId            String?       @unique  // iCal UID for OTA bookings (dedup)
  otaTaskId             String?       // auto-created StaffTask ID for incomplete OTA bookings
  porteirSentAt         DateTime?     // when the guest list was sent to the porteiro
  propertyId            String?
  cabinId               String?
  surveyStatus          SurveyStatus  @default(NAO_ENVIADO)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user        User?            @relation(fields: [userId], references: [id])
  property    Property?        @relation("PropertyBookings", fields: [propertyId], references: [id])
  cabin       Cabin?           @relation("CabinBookings", fields: [cabinId], references: [id])
  survey      Survey?
  inspections     InspectionReport[]
  maintenanceLogs MaintenanceLog[]
  coGuests        BookingGuest[]
  messages        GuestMessage[]
  guestList       GuestListEntry[]

  @@index([checkIn, checkOut])
  @@index([guestEmail])
  @@index([status])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum BookingSource {
  DIRECT
  AIRBNB
  BOOKING_COM
}

enum SurveyStatus {
  NAO_ENVIADO
  ENVIADO
  RESPONDIDO
}

// ── Blocked Dates (from iCal sync) ────────────────────────────────────────────
model BlockedDate {
  id         String      @id @default(cuid())
  date       DateTime    @db.Date
  source     BlockSource
  externalId String?
  summary    String?
  syncedAt   DateTime    @default(now())

  @@unique([date, source])
  @@index([date])
}

enum BlockSource {
  AIRBNB
  BOOKING_COM
  MANUAL
}

// ── Seasonal Pricing ──────────────────────────────────────────────────────────
model SeasonalPricing {
  id            String      @id @default(cuid())
  name          String
  tier          PricingTier
  startDate     DateTime    @db.Date
  endDate       DateTime    @db.Date
  pricePerNight Decimal     @db.Decimal(10, 2)
  minNights     Int         @default(2)
  propertyId    String?
  createdAt     DateTime    @default(now())

  property Property? @relation("PropertyPricing", fields: [propertyId], references: [id])

  @@index([startDate, endDate])
}

enum PricingTier {
  LOW
  MID
  HIGH_MID
  PEAK
}

// ── Multi-Property ────────────────────────────────────────────────────────────
model Property {
  id             String       @id @default(cuid())
  name           String
  slug           String       @unique
  type           PropertyType @default(SITIO)
  address        String?
  city           String?
  state          String?
  hasPool        Boolean      @default(false)
  icalAirbnb     String?
  icalBookingCom String?
  porteiroPhone  String?      // WhatsApp number for the porteiro (gate guard)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())

  cabins        Cabin[]
  bookings      Booking[]                 @relation("PropertyBookings")
  staff         StaffPropertyAssignment[]
  inspections   InspectionReport[]
  maintenance   MaintenanceLog[]
  tickets       ServiceTicket[]
  schedules     MaintenanceSchedule[]
  pricing       SeasonalPricing[]         @relation("PropertyPricing")
  suggestions   PricingSuggestion[]
  inventory     AmenitiesItem[]
  expenses      Expense[]
  conversations Conversation[]
  contentPosts       ContentPost[]
  brandContentConfigs BrandContentConfig[]
}

enum PropertyType {
  SITIO
  CABANA_COMPLEX
  CABANA
}

model Cabin {
  id          String   @id @default(cuid())
  propertyId  String
  name        String
  slug        String
  capacity    Int      @default(2)
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  property Property  @relation(fields: [propertyId], references: [id])
  bookings Booking[] @relation("CabinBookings")
}

// ── Staff ─────────────────────────────────────────────────────────────────────
model StaffMember {
  id                 String    @id @default(cuid())
  name               String
  email              String?   @unique
  phone              String?   @unique
  passwordHash       String?
  googleId           String?   @unique
  role               StaffRole
  fontSizePreference FontSize  @default(MD)
  firstLoginDone     Boolean   @default(false)
  pushSubscription   Json?
  active             Boolean   @default(true)
  inviteToken          String?
  inviteTokenExpiry    DateTime?
  passwordResetToken   String?
  passwordResetExpiry  DateTime?
  createdAt            DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  properties       StaffPropertyAssignment[]
  inspections      InspectionReport[]
  maintenanceLogs  MaintenanceLog[]
  tickets          ServiceTicket[]
  tasksAssigned    StaffTask[]         @relation("TaskAssignee")
  tasksCreated     StaffTask[]         @relation("TaskCreator")
  notifications    PushNotification[]
  pricingApprovals PricingSuggestion[]
  messages         GuestMessage[]
  webauthnCreds    WebAuthnCredential[]
  inboxMessages    InboxMessage[]
  emailSignature   String?
  inboxPushEnabled Boolean             @default(true)
  contentComments  ContentComment[]
}

enum StaffRole {
  ADMIN
  GUARDIA
  PISCINEIRO
}

enum FontSize {
  SM
  MD
  LG
  XL
}

model StaffPropertyAssignment {
  id         String      @id @default(cuid())
  staffId    String
  propertyId String
  createdAt  DateTime    @default(now())

  staff    StaffMember @relation(fields: [staffId], references: [id])
  property Property    @relation(fields: [propertyId], references: [id])

  @@unique([staffId, propertyId])
}

// ── Inspection Reports ────────────────────────────────────────────────────────
model InspectionReport {
  id               String           @id @default(cuid())
  bookingId        String
  propertyId       String
  staffId          String
  type             InspectionType
  status           InspectionStatus @default(DRAFT)
  signatureDataUrl String?          @db.Text  // deprecated — use signatureUrl
  signatureUrl     String?          // URL to stored signature file
  submittedAt      DateTime?
  notes            String?          @db.Text
  createdAt        DateTime         @default(now())

  booking  Booking           @relation(fields: [bookingId], references: [id])
  property Property          @relation(fields: [propertyId], references: [id])
  staff    StaffMember       @relation(fields: [staffId], references: [id])
  items    InspectionItem[]
  photos   InspectionPhoto[]
  videos   InspectionVideo[]
}

model InspectionVideo {
  id              String           @id @default(cuid())
  reportId        String
  storagePath     String
  storageUrl      String
  durationMs      Int?
  takenAt         DateTime         @default(now())
  originalDeleted Boolean          @default(false) // true after retention purge

  report InspectionReport @relation(fields: [reportId], references: [id])
}

enum InspectionType {
  PRE_CHECKIN
  CHECKOUT
}

enum InspectionStatus {
  DRAFT
  SUBMITTED
}

model InspectionItem {
  id                 String     @id @default(cuid())
  reportId           String
  category           String
  description        String
  status             ItemStatus @default(NAO_VERIFICADO)
  problemDescription String?
  createdAt          DateTime   @default(now())

  report InspectionReport @relation(fields: [reportId], references: [id])
  photos InspectionPhoto[]
}

enum ItemStatus {
  OK
  PROBLEMA
  NAO_VERIFICADO
}

model InspectionPhoto {
  id                 String   @id @default(cuid())
  reportId           String
  itemId             String?
  cloudinaryPublicId String   // relative storage path of the original
  cloudinaryUrl      String   // URL of the original (may 404 after retention purge)
  thumbnailUrl       String?  // URL of the thumbnail — kept forever
  caption            String?
  takenAt            DateTime @default(now())
  originalDeleted    Boolean  @default(false) // true after retention purge

  report InspectionReport  @relation(fields: [reportId], references: [id])
  item   InspectionItem?   @relation(fields: [itemId], references: [id])
}

// ── Maintenance ───────────────────────────────────────────────────────────────
model MaintenanceLog {
  id            String      @id @default(cuid())
  propertyId    String
  staffId       String
  bookingId     String?
  logType       String      @default("ROUTINE") // ROUTINE | PRE_CHECKIN
  visitDate     DateTime
  borderCleaned Boolean     @default(false)
  coverCleaned  Boolean     @default(false)
  vacuumed      Boolean     @default(false)
  waterTreated  Boolean     @default(false)
  filterCleaned Boolean     @default(false)
  checklistJson Json        @default("[]")      // flexible checklist items
  notes         String?
  photoUrls     Json        @default("[]")
  createdAt     DateTime    @default(now())

  property Property    @relation(fields: [propertyId], references: [id])
  staff    StaffMember @relation(fields: [staffId], references: [id])
  booking  Booking?    @relation(fields: [bookingId], references: [id])
}

model ServiceTicket {
  id          String         @id @default(cuid())
  propertyId  String
  openedById  String
  title       String
  description String         @db.Text
  photoUrls   Json           @default("[]")
  priority    TicketPriority @default(NORMAL)
  status      TicketStatus   @default(ABERTO)
  adminNotes  String?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  property Property    @relation(fields: [propertyId], references: [id])
  openedBy StaffMember @relation(fields: [openedById], references: [id])
}

enum TicketPriority {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

enum TicketStatus {
  ABERTO
  EM_ANDAMENTO
  RESOLVIDO
}

model MaintenanceSchedule {
  id              String   @id @default(cuid())
  propertyId      String
  item            String
  frequencyDays   Int
  lastDoneAt      DateTime?
  nextDueAt       DateTime
  alertDaysBefore Int      @default(7)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
}

// ── Amenities / Inventory ─────────────────────────────────────────────────────
model AmenitiesItem {
  id           String    @id @default(cuid())
  propertyId   String
  category     String
  name         String
  quantity     Int       @default(1)
  minQuantity  Int       @default(1)
  unit         String    @default("un")
  notes        String?
  lastChecked  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

// ── Suppliers ─────────────────────────────────────────────────────────────────
model Fornecedor {
  id        String   @id @default(cuid())
  name      String
  category  String
  phone     String?
  email     String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses  Expense[]
}

// ── Expenses ──────────────────────────────────────────────────────────────────
enum ExpenseCategory {
  SERVICOS_LIMPEZA
  MANUTENCAO_PISCINA
  PRODUTOS_LIMPEZA_PISCINA
  ENERGIA_ELETRICA
  GAS_COMBUSTIVEL          // botijão gás sauna/fogão (histórico — convertido p/ elétrico)
  INTERNET
  CONDOMINIO
  IMPOSTOS
  CARTAO_CREDITO
  MATERIAIS_MELHORIAS
  MANUTENCAO_SOLAR_BOMBA
  DESIGN_ARQUITETURA
  COMPRAS_ONLINE
  OUTROS
  A_CLASSIFICAR
}

enum ExpenseSource {
  BANK_IMPORT
  MANUAL
}

model Expense {
  id          String          @id @default(cuid())
  propertyId  String
  date        DateTime        @db.Date
  amount      Decimal         @db.Decimal(10, 2)
  category    ExpenseCategory @default(A_CLASSIFICAR)
  description String
  payee       String
  source      ExpenseSource   @default(MANUAL)
  bankRef     String?         @unique  // dedup key: "DD/MM/YYYY|payee|amount"
  supplierId  String?
  notes       String?
  createdAt   DateTime        @default(now())

  property   Property    @relation(fields: [propertyId], references: [id])
  supplier   Fornecedor? @relation(fields: [supplierId], references: [id])

  @@index([propertyId, date])
  @@index([category])
}

// ── Tasks ─────────────────────────────────────────────────────────────────────
model StaffTask {
  id           String     @id @default(cuid())
  assignedToId String
  assignedById String
  bookingId    String?
  title        String
  description  String?
  dueDate      DateTime?
  status       TaskStatus @default(PENDENTE)
  completedAt  DateTime?
  createdAt    DateTime   @default(now())

  assignedTo StaffMember @relation("TaskAssignee", fields: [assignedToId], references: [id])
  assignedBy StaffMember @relation("TaskCreator", fields: [assignedById], references: [id])
}

enum TaskStatus {
  PENDENTE
  FEITO
}

// ── Unified Inbox (SP4) ───────────────────────────────────────────────────────
model Conversation {
  id               String    @id @default(cuid())
  propertyId       String
  property         Property  @relation(fields: [propertyId], references: [id])
  contactName      String
  contactPhone     String?
  contactEmail     String?
  contactInstagram String?
  avatarUrl        String?
  lastMessageAt    DateTime?
  unreadCount      Int       @default(0)
  messages         InboxMessage[]
  createdAt        DateTime  @default(now())

  @@index([propertyId, lastMessageAt])
}

model InboxMessage {
  id             String      @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  staffId        String?
  staff          StaffMember? @relation(fields: [staffId], references: [id])
  direction      MsgDirection
  channel        MsgChannel
  body           String
  mediaUrl       String?
  isAiAgent      Boolean     @default(false)
  sentAt         DateTime    @default(now())
  readAt         DateTime?

  @@index([conversationId, sentAt])
}

enum MsgDirection {
  INBOUND
  OUTBOUND
}

enum MsgChannel {
  WHATSAPP
  INSTAGRAM
  EMAIL
}

// ── Guest List (SP3 pre-stay automation) ──────────────────────────────────────
model GuestListEntry {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])
  name      String
  vehicle   String?
  plate     String?
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([bookingId])
}

// ── Survey ────────────────────────────────────────────────────────────────────
model Survey {
  id                   String   @id @default(cuid())
  bookingId            String   @unique
  guestEmail           String
  sentAt               DateTime?
  respondedAt          DateTime?
  score                Int?
  comment              String?  @db.Text
  googleReviewLinkSent Boolean  @default(false)
  adminAlerted         Boolean  @default(false)
  createdAt            DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

// ── Guest Reputation ──────────────────────────────────────────────────────────
model GuestReputation {
  id            String         @id @default(cuid())
  userId        String         @unique
  totalStays    Int            @default(0)
  averageScore  Decimal        @default(0) @db.Decimal(3, 2)
  totalSpent    Decimal        @default(0) @db.Decimal(10, 2)
  reviewsGiven  Int            @default(0)
  incidentCount Int            @default(0)
  score         Int            @default(0)
  tier          ReputationTier @default(VISITANTE)
  lastUpdatedAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum ReputationTier {
  VISITANTE
  AMIGO
  AMIGO_DA_CASA
  VIP
  FAMILIA
}

// ── Pricing Suggestions (IA) ──────────────────────────────────────────────────
model PricingSuggestion {
  id             String           @id @default(cuid())
  propertyId     String
  periodStart    DateTime
  periodEnd      DateTime
  currentPrice   Decimal          @db.Decimal(10, 2)
  suggestedPrice Decimal          @db.Decimal(10, 2)
  reason         String           @db.Text
  status         SuggestionStatus @default(PENDENTE)
  acceptedById   String?
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())

  property   Property     @relation(fields: [propertyId], references: [id])
  acceptedBy StaffMember? @relation(fields: [acceptedById], references: [id])
}

enum SuggestionStatus {
  PENDENTE
  ACEITA
  REJEITADA
}

// ── Co-Guest Invitations ──────────────────────────────────────────────────────
model BookingGuest {
  id           String            @id @default(cuid())
  bookingId    String
  addedById    String
  name         String
  email        String
  phone        String?
  inviteToken  String?           // SHA-256 hash, 72h expiry
  inviteExpiry DateTime?
  status       GuestInviteStatus @default(PENDENTE)
  userId       String?
  createdAt    DateTime          @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  addedBy User    @relation("GuestsAdded",  fields: [addedById], references: [id])
  user    User?   @relation("GuestProfile", fields: [userId],    references: [id])

  @@index([bookingId])
  @@index([inviteToken])
}

enum GuestInviteStatus {
  PENDENTE
  CONFIRMADO
  CANCELADO
}

// ── WebAuthn Credentials ──────────────────────────────────────────────────────
model WebAuthnCredential {
  id           String      @id @default(cuid())
  staffId      String
  credentialId String      @unique  // base64url-encoded credential ID
  publicKey    Bytes
  counter      BigInt      @default(0)
  transports   String[]
  createdAt    DateTime    @default(now())
  lastUsedAt   DateTime?

  staff StaffMember @relation(fields: [staffId], references: [id])

  @@index([staffId])
}

// ── Guest Messages ────────────────────────────────────────────────────────────
model GuestMessage {
  id        String           @id @default(cuid())
  bookingId String
  staffId   String?
  direction MessageDirection
  channel   String           @default("MANUAL") // WHATSAPP | EMAIL | MANUAL
  body      String           @db.Text
  sentAt    DateTime         @default(now())

  booking Booking      @relation(fields: [bookingId], references: [id])
  staff   StaffMember? @relation(fields: [staffId], references: [id])

  @@index([bookingId])
  @@index([sentAt])
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

// ── AI Content Agent (SP5) ───────────────────────────────────────────────────

model BrandContentConfig {
  id              String   @id @default(cuid())
  brand           Brand
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id])
  voiceNotes      String?  @db.Text
  upcomingThemes  String?  @db.Text
  pillarMix       Json?    // { experiencia: 30, destino: 20, ... }
  postsPerWeek    Int      @default(5)
  postingSchedule Json?    // [{ day: "MON", time: "10:00", platform: "INSTAGRAM" }]
  defaultHashtags String?
  updatedAt       DateTime @updatedAt

  @@unique([brand, propertyId])
}

model ContentPost {
  id           String         @id @default(cuid())
  brand        Brand
  propertyId   String
  property     Property       @relation(fields: [propertyId], references: [id])
  title        String
  body         String?        @db.Text
  contentType  ContentType
  pillar       ContentPillar?
  stage        ContentStage   @default(GERADO)
  aiGenerated  Boolean        @default(false)
  ghlPostId    String?
  scheduledFor DateTime?
  publishedAt  DateTime?
  mediaUrls    Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  comments ContentComment[]

  @@index([brand, stage])
  @@index([propertyId])
}

model ContentComment {
  id        String      @id @default(cuid())
  postId    String
  post      ContentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  staffId   String
  staff     StaffMember @relation(fields: [staffId], references: [id])
  body      String      @db.Text
  createdAt DateTime    @default(now())

  @@index([postId])
}

enum Brand {
  RDI
  RDS
  CDS
}

enum ContentType {
  INSTAGRAM_FEED
  INSTAGRAM_REELS
  INSTAGRAM_STORIES
  FACEBOOK
  BLOG
}

enum ContentPillar {
  EXPERIENCIA
  DESTINO
  PROVA_SOCIAL
  DISPONIBILIDADE
  BASTIDORES
  BLOG_SEO
}

enum ContentStage {
  GERADO
  EM_REVISAO
  APROVADO
  AGENDADO
  PUBLICADO
}

// ── Push Notifications ────────────────────────────────────────────────────────
model PushNotification {
  id      String      @id @default(cuid())
  staffId String
  title   String
  body    String
  type    String
  data    Json?
  read    Boolean     @default(false)
  sentAt  DateTime    @default(now())

  staff StaffMember @relation(fields: [staffId], references: [id])
}
